import React, { useState, useEffect, useRef } from 'react';
import { Target, Play, Database, Brain, RotateCcw, Activity, TrendingUp, Info, CheckCircle2, AlertCircle, Trash2 } from 'lucide-react';

// TensorFlow.js를 CDN에서 로드
const loadTF = () => {
  return new Promise((resolve) => {
    if (window.tf) {
      resolve(window.tf);
      return;
    }
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.15.0/dist/tf.min.js';
    script.onload = () => resolve(window.tf);
    document.head.appendChild(script);
  });
};

const App = () => {
  const [data, setData] = useState([]);
  const [angle, setAngle] = useState(30);
  const [targetDistance, setTargetDistance] = useState(60);
  const [isFiring, setIsFiring] = useState(false);
  const [projectile, setProjectile] = useState(null);
  const [isTraining, setIsTraining] = useState(false);
  const [model, setModel] = useState(null);
  const [trainingStatus, setTrainingStatus] = useState("데이터를 수집해주세요");
  const [lossHistory, setLossHistory] = useState([]); 
  const [prediction, setPrediction] = useState(null);
  const [lastResult, setLastResult] = useState(null);
  const [tfLoaded, setTfLoaded] = useState(false);
  const [learnedCurve, setLearnedCurve] = useState([]);

  const animationRef = useRef(null);

  // 물리 상수
  const GRAVITY = 9.8;
  const VELOCITY = 30;
  const VISUAL_SCALE = 7.5; 
  const OFFSET_X = 50;
  const GROUND_Y = 350;

  useEffect(() => {
    loadTF().then(() => setTfLoaded(true));
    return () => {
      if (animationRef.current) cancelAnimationFrame(animationRef.current);
    };
  }, []);

  // AI 추론 곡선 업데이트
  useEffect(() => {
    const updateCurve = async () => {
      if (model && window.tf) {
        const tf = window.tf;
        const distances = [];
        for (let d = 0; d <= 100; d += 2) distances.push(d / 100);
        
        const input = tf.tensor2d(distances, [distances.length, 1]);
        const result = model.predict(input);
        const output = await result.data();
        
        const curvePoints = distances.map((d, i) => ({
          x: d * 100,
          y: output[i] * 45
        }));
        
        setLearnedCurve(curvePoints);
        input.dispose();
        result.dispose();
      }
    };
    updateCurve();
  }, [model]);

  // 실시간 예측 (가이드)
  useEffect(() => {
    const updatePrediction = async () => {
      if (model && window.tf) {
        const tf = window.tf;
        const input = tf.tensor2d([[targetDistance / 100]]);
        const result = model.predict(input);
        const predictedData = await result.data();
        setPrediction(predictedData[0] * 45);
        input.dispose();
        result.dispose();
      }
    };
    updatePrediction();
  }, [targetDistance, model]);

  // 시뮬레이션 초기화 기능
  const resetSimulation = () => {
    setData([]);
    setModel(null);
    setPrediction(null);
    setLossHistory([]);
    setLearnedCurve([]);
    setLastResult(null);
    setTrainingStatus("데이터를 수집해주세요");
  };

  const fire = (launchAngle) => {
    if (isFiring || isNaN(launchAngle)) return;
    setIsFiring(true);
    setLastResult(null);

    const rad = (launchAngle * Math.PI) / 180;
    const vx = VELOCITY * Math.cos(rad);
    const vy = -VELOCITY * Math.sin(rad);
    
    let t = 0;

    const animate = () => {
      t += 0.08; 
      const x = OFFSET_X + vx * t * VISUAL_SCALE;
      const y = GROUND_Y + (vy * t + 0.5 * GRAVITY * t * t) * VISUAL_SCALE;
      
      setProjectile({ x, y });

      if (y > GROUND_Y) {
        const dist = (Math.pow(VELOCITY, 2) * Math.sin(2 * rad)) / GRAVITY;
        setIsFiring(false);
        setProjectile(null);
        const result = { angle: launchAngle, distance: dist, timestamp: Date.now() };
        setLastResult(result);
        setData(prev => [...prev, result].slice(-30));
        return;
      }
      animationRef.current = requestAnimationFrame(animate);
    };
    animate();
  };

  const trainModel = async () => {
    if (data.length < 5) return;
    setIsTraining(true);
    setLossHistory([]); 
    setTrainingStatus("심층 신경망 구성 중...");

    const tf = window.tf;
    const xs = tf.tensor2d(data.map(d => [d.distance / 100])); 
    const ys = tf.tensor2d(data.map(d => [d.angle / 45]));

    const newModel = tf.sequential();
    newModel.add(tf.layers.dense({ units: 64, inputShape: [1], activation: 'tanh' }));
    newModel.add(tf.layers.dense({ units: 32, activation: 'tanh' }));
    newModel.add(tf.layers.dense({ units: 1, activation: 'sigmoid' }));

    newModel.compile({ 
      optimizer: tf.train.adam(0.015), 
      loss: 'meanSquaredError' 
    });

    await newModel.fit(xs, ys, {
      epochs: 1200,
      shuffle: true,
      callbacks: {
        onEpochEnd: (epoch, logs) => {
          if (epoch % 20 === 0) {
            setLossHistory(prev => [...prev, logs.loss]);
            if (epoch % 100 === 0) {
                setTrainingStatus(`학습 진행률: ${Math.round((epoch/1200)*100)}%`);
            }
          }
        }
      }
    });

    setModel(newModel);
    setIsTraining(false);
    setTrainingStatus(model ? "재학습 완료! 데이터가 업데이트되었습니다." : "학습 완료! AI 가이드가 활성화되었습니다.");
    xs.dispose();
    ys.dispose();
  };

  // 샘플 다양성 체크 (범위 확장 반영: 5~15도 구간, 35~45도 구간)
  const hasLowAngle = data.some(d => d.angle <= 15);
  const hasHighAngle = data.some(d => d.angle >= 35);

  const maxLoss = lossHistory.length > 0 ? Math.max(...lossHistory) : 1;
  const currentLoss = lossHistory.length > 0 ? lossHistory[lossHistory.length - 1] : null;

  return (
    <div className="flex flex-col min-h-screen bg-slate-950 text-white p-4 font-sans text-white">
      <header className="flex items-center justify-between mb-6 border-b border-slate-800 pb-4">
        <div className="flex items-center gap-4">
          <div className="bg-white p-2 rounded-xl shadow-lg shadow-white/10">
            <Brain size={32} className="text-slate-900" />
          </div>
          <div className="flex flex-col">
            <div className="flex items-baseline gap-2">
              <h1 className="text-2xl font-bold text-white tracking-tight uppercase">
                AI 학습기반 투석기
              </h1>
              <span className="text-sm font-bold text-slate-300">
                Ver 3.0
              </span>
            </div>
            <p className="text-slate-400 text-[11px] font-medium tracking-wide mt-0.5">
              Developed by Kim Byeong-du
            </p>
          </div>
        </div>
        <div className="bg-slate-900 px-5 py-2.5 rounded-2xl border border-slate-800 flex items-center gap-3 text-white">
          <div className="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
          <div className="flex flex-col">
            <p className="text-emerald-400 text-[10px] font-bold uppercase tracking-widest leading-none">Neural Engine Online</p>
          </div>
        </div>
      </header>

      <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div className="lg:col-span-3 space-y-4">
          {/* 1. 데이터 수집 섹션 - 범위 수정 (5~45°) */}
          <div className="bg-slate-900 border border-slate-800 p-5 rounded-3xl shadow-xl border-indigo-500/10">
            <div className="flex justify-between items-center mb-4 text-white">
              <h2 className="text-indigo-400 font-black text-[11px] flex items-center gap-2 tracking-widest uppercase">
                <Database size={14} /> 1. 데이터 수집 (5~45°)
              </h2>
              <button 
                onClick={resetSimulation}
                className="p-1.5 hover:bg-rose-500/20 rounded-lg text-slate-500 hover:text-rose-400 transition-colors"
                title="전체 데이터 및 모델 초기화"
              >
                <Trash2 size={16} />
              </button>
            </div>
            <div className="space-y-5">
              <div>
                <div className="flex justify-between text-xs text-slate-400 mb-2 font-bold">
                  <span>조준 각도 설정 슬라이더</span>
                  <span className="text-indigo-400 font-mono text-base">{angle}°</span>
                </div>
                <input 
                  type="range" min="5" max="45" value={angle} 
                  onChange={(e) => setAngle(parseInt(e.target.value))}
                  className="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-indigo-500"
                />
              </div>
              <button 
                onClick={() => fire(angle)}
                disabled={isFiring}
                className="w-full bg-indigo-600 hover:bg-indigo-500 disabled:bg-slate-800 py-3.5 rounded-2xl font-black flex items-center justify-center gap-2 transition-all active:scale-95 text-sm text-white"
              >
                <Play size={16} fill="currentColor" /> 투석기 발사
              </button>
            </div>
          </div>

          {/* 2. AI 신경망 학습 섹션 */}
          <div className="bg-slate-900 border border-slate-800 p-5 rounded-3xl shadow-xl">
            <div className="mb-4">
              <h2 className="text-emerald-400 font-black text-[11px] flex items-center gap-2 tracking-widest uppercase mb-1">
                <Activity size={14} /> 2. AI 신경망 학습
              </h2>
              <p className="text-slate-500 text-[10px] font-medium px-5">Powered by TensorFlow.js</p>
            </div>
            <div className="space-y-3">
              <div className="bg-slate-950 p-4 rounded-2xl border border-slate-800 space-y-3">
                <div className="flex justify-between items-center text-xs">
                  <span className="text-slate-500 font-bold tracking-tight">샘플 다양성</span>
                  <div className="flex gap-1">
                    {hasLowAngle ? <CheckCircle2 size={12} className="text-emerald-500" /> : <AlertCircle size={12} className="text-slate-700" />}
                    {hasHighAngle ? <CheckCircle2 size={12} className="text-emerald-500" /> : <AlertCircle size={12} className="text-slate-700" />}
                  </div>
                </div>
                <div className="flex justify-between text-xs font-bold">
                  <span className="text-slate-500">데이터 양</span>
                  <span className={data.length >= 8 ? "text-emerald-400" : "text-amber-500"}>{data.length} 샘플</span>
                </div>
                <div className="h-1 w-full bg-slate-800 rounded-full overflow-hidden">
                   <div className="h-full bg-emerald-500 transition-all duration-500" style={{width: `${Math.min(100, (data.length/10)*100)}%`}}></div>
                </div>
                <p className="text-slate-400 text-[10px] leading-relaxed italic text-white">{trainingStatus}</p>
              </div>
              <button 
                onClick={trainModel}
                disabled={data.length < 5 || isTraining}
                className="w-full bg-emerald-600 hover:bg-emerald-500 disabled:bg-slate-800 py-3.5 rounded-2xl font-black flex items-center justify-center gap-2 transition-all active:scale-95 text-sm text-white"
              >
                {isTraining ? <RotateCcw className="animate-spin" size={16} /> : <Brain size={16} />}
                {model ? "데이터 기반 재학습" : "딥러닝 학습 시작"}
              </button>
            </div>
          </div>

          {/* 3. AI 학습모델 예측 가이드 섹션 */}
          <div className="bg-slate-900 border border-slate-800 p-5 rounded-3xl shadow-xl border-rose-500/10">
            <h2 className="text-rose-400 font-black text-[11px] mb-4 flex items-center gap-2 tracking-widest uppercase">
              <Target size={14} /> 3. AI 학습모델 예측 가이드
            </h2>
            <div className="space-y-4">
              <div>
                <div className="flex justify-between text-xs text-slate-400 mb-2 font-bold">
                  <span>목표 지점 설정 슬라이더</span>
                  <span className="text-rose-400 font-mono text-base">{targetDistance}m</span>
                </div>
                <input 
                  type="range" min="10" max="92" value={targetDistance} 
                  onChange={(e) => setTargetDistance(parseInt(e.target.value))}
                  disabled={!model}
                  className="w-full h-1.5 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-rose-500 disabled:opacity-20"
                />
              </div>
              <div className="bg-rose-500/5 border border-rose-500/10 p-5 rounded-2xl text-center">
                <p className="text-[9px] text-slate-600 font-black uppercase mb-1 tracking-widest">AI 추천 조준 각도</p>
                <div className="text-4xl font-black text-rose-500 font-mono tracking-tighter text-rose-500">
                  {prediction ? `${prediction.toFixed(1)}°` : "---"}
                </div>
                {!model && <p className="text-[9px] text-slate-500 mt-2 font-bold">학습 후 목표가 활성화됩니다</p>}
              </div>
            </div>
          </div>
        </div>

        {/* 메인 뷰 */}
        <div className="lg:col-span-9 space-y-6">
          <div className="bg-slate-900 rounded-[2.5rem] border border-slate-800 overflow-hidden relative shadow-2xl h-[400px]">
            <div className="absolute top-6 left-6 z-10 flex items-center gap-3">
              <div className="bg-slate-950/90 px-4 py-2 rounded-xl border border-slate-800 backdrop-blur-xl flex items-center gap-3 shadow-2xl text-white text-white">
                <div className={`w-2 h-2 rounded-full ${model ? 'bg-rose-500 animate-pulse' : 'bg-slate-700'}`}></div>
                <span className="text-[10px] font-black tracking-wider uppercase">
                  {model ? 'AI 예측 모드 활성화됨' : '데이터 수집 대기 중...'}
                </span>
              </div>
            </div>

            <svg width="100%" height="100%" viewBox="0 0 800 400" className="bg-slate-950 bg-slate-950">
              <defs>
                <linearGradient id="groundGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stopColor="#1e293b" />
                  <stop offset="100%" stopColor="#0f172a" />
                </linearGradient>
              </defs>
              
              <line x1="0" y1={GROUND_Y} x2="800" y2={GROUND_Y} stroke="#334155" strokeWidth="2" />
              <rect x="0" y={GROUND_Y} width="800" height="50" fill="url(#groundGrad)" />
              
              <g transform="translate(40, 40)">
                <rect width="130" height={Math.max(40, 20 + Math.min(15, data.length) * 16)} rx="12" fill="#0f172a" fillOpacity="0.8" stroke="#1e293b" strokeWidth="1" />
                <text x="10" y="18" fontSize="9" fontWeight="black" fill="#6366f1" className="uppercase tracking-widest text-indigo-500">최근 발사 로그</text>
                {data.length === 0 ? (
                  <text x="10" y="35" fontSize="9" fill="#475569" fontStyle="italic">데이터 없음...</text>
                ) : (
                  data.slice(-15).reverse().map((d, i) => (
                    <g key={i} transform={`translate(10, ${36 + i * 16})`}>
                      <text fontSize="10" fill="#94a3b8" fontWeight="bold" className="font-mono text-slate-400">
                        {d.angle.toFixed(0)}° → {d.distance.toFixed(1)}m
                      </text>
                    </g>
                  ))
                )}
              </g>

              {model && (
                <g transform={`translate(${OFFSET_X + targetDistance * VISUAL_SCALE}, ${GROUND_Y})`}>
                  <circle r="20" fill="#f43f5e" fillOpacity="0.05" />
                  <circle r="6" fill="#f43f5e" />
                  <line y1="-30" y2="10" stroke="#f43f5e" strokeWidth="1.5" strokeDasharray="3,3" />
                  <text y="-40" textAnchor="middle" fontSize="9" fontWeight="black" fill="#f43f5e" className="uppercase tracking-widest text-rose-500">목표</text>
                </g>
              )}

              <g transform={`translate(${OFFSET_X}, ${GROUND_Y})`}>
                <rect x="-25" y="-12" width="50" height="12" fill="#1e293b" rx="2" />
                {prediction && (
                    <line 
                      x1="0" y1="-6" 
                      x2={60 * Math.cos((prediction * Math.PI) / 180)} 
                      y2={-60 * Math.sin((prediction * Math.PI) / 180)} 
                      stroke="#f43f5e" strokeWidth="1.5" strokeDasharray="4,4" opacity="0.4"
                    />
                )}
                <line 
                  x1="0" y1="-6" 
                  x2={50 * Math.cos((angle * Math.PI) / 180)} 
                  y2={-50 * Math.sin((angle * Math.PI) / 180)} 
                  stroke="#6366f1" 
                  strokeWidth="8" strokeLinecap="round"
                  className="transition-all duration-200"
                />
              </g>

              {projectile && (
                <circle cx={projectile.x} cy={projectile.y} r="8" fill="#fbbf24" className="filter drop-shadow-[0_0_15px_rgba(251,191,36,0.9)]" />
              )}

              {lastResult && (
                <g transform={`translate(${OFFSET_X + lastResult.distance * VISUAL_SCALE}, ${GROUND_Y})`}>
                    <path d="M -8 -15 L 0 0 L 8 -15 Z" fill="#fbbf24" />
                    <text textAnchor="middle" fontSize="10" fontWeight="black" fill="#fbbf24" y="-20" className="font-mono text-amber-400">{lastResult.distance.toFixed(1)}m</text>
                </g>
              )}

              {[0, 20, 40, 60, 80, 100].map(m => (
                <text key={m} x={OFFSET_X + m * VISUAL_SCALE} y={GROUND_Y + 30} fontSize="10" fill="#475569" textAnchor="middle" fontWeight="black" className="font-mono">{m}m</text>
              ))}
            </svg>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div className="bg-slate-900 border border-slate-800 p-8 rounded-[2.5rem] shadow-xl relative overflow-hidden">
              <h3 className="text-[10px] font-black text-slate-500 mb-6 flex items-center gap-3 uppercase tracking-[0.25em]">
                <TrendingUp size={16} className="text-rose-500" /> 신경망 상관관계 (데이터 분포)
              </h3>
              <div className="h-[180px] relative px-2 text-center text-white font-sans text-white text-white">
                <svg width="100%" height="100%" viewBox="0 0 100 100" preserveAspectRatio="none" className="overflow-visible">
                  <line x1="0" y1="100" x2="100" y2="100" stroke="#334155" strokeWidth="1" />
                  <line x1="0" y1="0" x2="0" y2="100" stroke="#334155" strokeWidth="1" />
                  
                  {data.map((pt, i) => (
                    <circle 
                      key={i} 
                      cx={pt.distance} 
                      cy={100 - (pt.angle / 45 * 100)} 
                      r="2" 
                      fill="#6366f1" 
                      fillOpacity="0.4"
                    />
                  ))}

                  {learnedCurve.length > 1 && (
                    <polyline
                      fill="none"
                      stroke="#f43f5e"
                      strokeWidth="2.5"
                      strokeLinejoin="round"
                      points={learnedCurve.map(p => `${p.x},${100 - (p.y / 45 * 100)}`).join(' ')}
                      className="drop-shadow-[0_0_8px_rgba(244,63,94,0.4)]"
                    />
                  )}
                  
                  {prediction && (
                    <line x1={targetDistance} y1="0" x2={targetDistance} y2="100" stroke="#f43f5e" strokeWidth="1" strokeDasharray="2,2" />
                  )}
                </svg>
                <div className="flex justify-between mt-4 text-[9px] text-slate-600 font-black font-mono tracking-widest uppercase">
                  <span>0m</span>
                  <span className="text-indigo-500/50 uppercase tracking-tighter">Data Analysis & Curve Fitting</span>
                  <span>100m</span>
                </div>
              </div>
            </div>

            <div className="bg-slate-900 border border-slate-800 p-8 rounded-[2.5rem] shadow-xl relative overflow-hidden group">
               <div className="flex justify-between items-center mb-6 text-white">
                <h3 className="text-[10px] font-black text-slate-500 flex items-center gap-3 uppercase tracking-[0.25em]">
                  <Activity size={16} className="text-indigo-500" /> 실시간 학습 오차 (Loss Curve)
                </h3>
                {isTraining && <div className="text-[9px] text-emerald-400 font-bold animate-pulse tracking-tighter uppercase text-emerald-500">Optimizing...</div>}
               </div>
               
               <div className="h-[180px] relative mt-2 px-2 text-white">
                 {currentLoss !== null && (
                    <div className="absolute top-0 right-0 text-right z-20">
                        <div className="text-[10px] text-slate-500 font-bold uppercase tracking-tight">Current Loss</div>
                        <div className="text-xl font-black text-indigo-400 font-mono leading-none text-indigo-400">
                            {currentLoss.toFixed(6)}
                        </div>
                    </div>
                 )}

                 <svg width="100%" height="100%" viewBox="0 0 100 100" preserveAspectRatio="none" className="overflow-visible">
                   {[20, 40, 60, 80].map(v => (
                     <line key={v} x1="0" y1={v} x2="100" y2={v} stroke="#1e293b" strokeWidth="0.5" />
                   ))}
                   <line x1="0" y1="100" x2="100" y2="100" stroke="#334155" strokeWidth="1.5" />
                   <line x1="0" y1="0" x2="0" y2="100" stroke="#334155" strokeWidth="1.5" />
                   
                   {lossHistory.length > 1 ? (
                     <g>
                       <path
                         d={`M 0 100 ${lossHistory.map((l, i) => `${(i / (lossHistory.length - 1)) * 100},${100 - Math.min(95, (l / maxLoss) * 90 + 5)}`).join(' L ')} L 100 100 Z`}
                         fill="url(#lossFill)"
                         className="opacity-20"
                       />
                       <polyline
                         fill="none"
                         stroke="#6366f1"
                         strokeWidth="2.5"
                         strokeLinecap="round"
                         strokeLinejoin="round"
                         points={lossHistory.map((l, i) => `${(i / (lossHistory.length - 1)) * 100},${100 - Math.min(95, (l / maxLoss) * 90 + 5)}`).join(' ')}
                         className="drop-shadow-[0_0_5px_rgba(99,102,241,0.5)]"
                       />
                       <text x="2" y={100 - (lossHistory[0]/maxLoss * 90 + 5)} fontSize="5" fill="#475569" fontWeight="bold">{lossHistory[0].toFixed(4)}</text>
                       <text x="98" y={100 - (currentLoss/maxLoss * 90 + 5)} fontSize="5" fill="#6366f1" fontWeight="bold" textAnchor="end">{currentLoss.toFixed(4)}</text>
                     </g>
                   ) : (
                     <text x="50" y="50" textAnchor="middle" fontSize="5" fill="#475569" className="italic font-bold uppercase tracking-widest text-center">학습 데이터 수집 중</text>
                   )}
                   
                   <defs>
                     <linearGradient id="lossFill" x1="0" y1="0" x2="0" y2="100%">
                       <stop offset="0%" stopColor="#6366f1" />
                       <stop offset="100%" stopColor="#6366f1" stopOpacity="0" />
                     </linearGradient>
                   </defs>
                 </svg>
                 
